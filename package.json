{
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky",
    "clean": "find . -name \"node_modules\" -type d -prune -exec rm -rf '{}' + && pnpm install",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "eslint": "^9.18.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.2.5",
    "turbo": "^2.7.5",
    "@repo/prettier-config": "workspace:*"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,md,json}": [
      "prettier --write"
    ]
  },
  "prettier": "@repo/prettier-config",
  "packageManager": "pnpm@8.15.6",
  "pnpm": {
    "overrides": {
      "@tanstack/react-query": "^5.90.21",
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "@react-navigation/native": "^7.1.28"
    }
  },
  "name": "vitalpathai"
}
