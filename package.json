    "lint-staged": "^16.2.7",
    "prettier": "^3.2.5",
    "turbo": "^2.7.5"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,md,json}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@8.15.6",
